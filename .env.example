# fal.ai — video generation (Kling, Wan)
# Get key at https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Anthropic — Claude script generation
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_KEY=your_anthropic_key_here

# ElevenLabs — optional voiceover
# Get key at https://elevenlabs.io/app/settings/api-keys
# Leave blank to skip voiceover step
ELEVENLABS_KEY=your_elevenlabs_key_here

# YouTube Data API v3 — optional, enables sort-by-views in /analyze-channel
# Get key at https://console.cloud.google.com/apis/credentials
# Without this, /analyze-channel falls back to yt-dlp (recent order instead of top by views)
YOUTUBE_API_KEY=your_youtube_api_key_here
